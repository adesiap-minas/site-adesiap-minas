{return e.app.settings.portalBucket},classificationOptions:function(e){return e.classification.options},enabledClassificationOptions:function(e){return e.classification.enabledOptions},classificationFieldLabels:function(e){return e.classification.fieldLabels}},A=y;i["default"].use(t["a"]);var S=new t["a"].Store({modules:{app:m,classification:v},getters:A});a["a"]=S},b614:function(e){e.exports=JSON.parse('{"labels":{"protocol":"Protokoll","home":"Startseite","search":"Suchen","response":"Zusätzliche Informationen und Antworten.","responseDesc":"Nutzen Sie diesen Bereich, um zusätzliche Informationen bereitzustellen, Fragen zu beantworten oder mit unserem Team zu interagieren. Ihre Mitarbeit ist für den Abschluss des Verfahrens unerlässlich.","sendResponse":"Antwort senden","insertNewInformation":"Neue Informationen zu Ihrem Protokoll hinzufügen","insertNewInformationDesc":"Sie können dieses Feld verwenden, um Informationen zu Ihrem Protokoll hinzuzufügen","sendInformation":"Informationen senden","newSearch":"Neue Suche","back":"Zurück","next":"Weiter","finish":"Abschließen","yes":"Ja","no":"Nein"},"home":{"title":"Meldekanal {0}","introductionText":"Sie befinden sich in einer sicheren Umgebung, die außerhalb von {0} gehostet und von Conformità Gestão de Compliance verwaltet wird. Wir fördern eine unabhängige Umgebung, um den Empfang und die Bearbeitung von Meldungen sowie die Vertraulichkeit der Informationen zu gewährleisten.","instructionText":"Dieser Kanal richtet sich an das interne Publikum von {0}. Sie können zur Schaffung einer ethischeren Umgebung beitragen, indem Sie Verstöße gegen Regeln und/oder Gesetze, Straftaten, Betrug, Belästigung, Diskriminierung und jede andere Situation melden, die {0} oder die Integrität von Personen schädigt. Ihre Mitarbeit ist unerlässlich, um ein immer ethischeres Umfeld zu erreichen. Wir sind alle dankbar für Ihre Haltung. Um den Fortschritt Ihrer Meldung zu verfolgen, klicken Sie unten auf \\"Verfolgen\\".","phoneService":"Sie können Ihren Bericht über das Internet senden, indem Sie unten auf die Schaltfläche klicken. Wenn Sie Ihren Bericht telefonisch einreichen möchten, können Sie kostenlos unter {0} anrufen.","btn":{"report":"Melden","communicate":"Melden","qas":"Fragen und Anregungen","followup":"Verfolgen","ombudsman":"Ombudsstelle","dsar":"Personenbezogene Daten"}},"followup":{"title":"Protokoll verfolgen","instruction":"Um den Fortschritt Ihrer Mitteilung zu verfolgen, geben Sie bitte unten die generierte Protokollnummer oder die interne Vorgangsnummer ein.","resultTitle":"Registrierte Begleitungen für das Protokoll","receivedDay":"Anfrage eingegangen am","receivedTime":"um","successResponse":"Antwort erfolgreich gesendet!"},"qas":{"title":"Formular zum Senden von Fragen oder Anregungen","introduction":"Wenn Sie eine Frage oder Anregung zu ethischen Themen, Integrität, Richtlinien und internen Prozessen oder einem anderen relevanten Thema haben, können Sie diesen Kanal nutzen. Der Inhalt der Frage oder Anregung wird vom zuständigen Bereich bewertet und Sie erhalten innerhalb einer angemessenen Frist eine Antwort. Sie können sich identifizieren oder anonym bleiben. Wir garantieren den Schutz Ihrer Informationen. Notieren Sie sich am Ende die generierte Protokollnummer, um die Antwort auf Ihre Anfrage einzusehen.","instruction":"Füllen Sie das folgende Formular mit so vielen Informationen und Details wie möglich aus, um dem zuständigen Team das Verständnis zu erleichtern. Beim Fortfahren können Sie Dateien anhängen.","success":"Frage/Anregung erfolgreich gesendet!","successInfo1":"Ihre Anfrage wurde empfangen und wird innerhalb einer angemessenen Frist bearbeitet.","successInfo2":"Notieren Sie sich die generierte Protokollnummer, damit Sie die Antwort auf Ihre Anfrage einsehen können.","information":"Informationen","attachments":"Anhänge","attachmentInfo":"Auf diesem Bildschirm können Sie Dateien anhängen, die die Gründe für Ihre Frage oder Anregung belegen. Zum Abschließen klicken Sie auf Abschließen.","fields":{"anonymous":"Möchten Sie sich identifizieren?","relation":"In welcher Beziehung stehen Sie zu {0}?","text":"Schreiben Sie Ihre Frage/Anregung"},"fieldsDesc":{"text":"Beschreiben Sie Ihre Fragen/Anregungen so detailliert wie möglich. Geben Sie wenn möglich den Bereich/die Abteilung an, auf den/die Sie sich beziehen"}},"dsar":{"title":"Anfragen zu personenbezogenen Daten","introduction":"Über dieses Formular kann die betroffene Person oder der gesetzliche Vertreter Anfragen zu personenbezogenen Daten einreichen, die gemäß den Richtlinien des Allgemeinen Datenschutzgesetzes behandelt werden. Wir möchten durch diese Umgebung den Zugang der Nutzer zu ihren Rechten erleichtern sowie die Einreichung, Protokollierung und Nachverfolgung ihrer Anfragen ermöglichen. Die auf dieser und anderen Seiten dieses Portals erhobenen Daten werden ausschließlich zum Zweck der Bearbeitung und Registrierung von Anfragen/Anliegen der betroffenen Person verarbeitet.","instruction":"Füllen Sie das folgende Formular mit so vielen Informationen und Details wie möglich aus, um dem zuständigen Team das Verständnis zu erleichtern. Bei Angabe einer E-Mail-Adresse erhalten Sie eine Protokollbestätigung und Folgebenachrichtigungen. Beim Fortfahren können Sie Dateien anhängen.","success":"Anfrage erfolgreich gesendet!","successInfo1":"Ihre Anfrage wurde empfangen und wird innerhalb von 15 Tagen bearbeitet.","successInfo2":"Notieren Sie sich die generierte Protokollnummer, damit Sie den Fortschritt und die Antworten auf Ihre Anfrage einsehen können. Wenn Sie eine E-Mail-Adresse angegeben haben, überprüfen Sie Ihren Posteingang.","information":"Kontaktinformationen","attachments":"Anhänge","attachmentInfo":"Auf diesem Bildschirm können Sie Dateien anhängen, die die Gründe für Ihre Anfrage belegen. Zum Abschließen klicken Sie auf Abschließen.","fields":{"text":"Schreiben Sie Ihre Anfrage"},"fieldsDesc":{"text":"Beschreiben Sie Ihre Anfrage so detailliert wie möglich."}},"ombudsman":{"title":"Ombudsstelle","introduction":"Der Ombudskanal sollte als letztes Mittel genutzt werden. Er nimmt Anfragen entgegen, die von anderen Bereichen der Organisation nicht gelöst wurden. Bevor Sie die Ombudsstelle kontaktieren, ist es daher wichtig, zu versuchen, das Problem mit dem Kundenservice zu lösen.","instruction":"Füllen Sie das folgende Formular mit so vielen Informationen und Details wie möglich aus, um dem zuständigen Team das Verständnis zu erleichtern. Bei Angabe einer E-Mail-Adresse erhalten Sie eine Protokollbestätigung und Folgebenachrichtigungen. Beim Fortfahren können Sie Dateien anhängen.","success":"Anfrage erfolgreich gesendet!","successInfo1":"Ihre Anfrage wurde empfangen und wird innerhalb von 10 Tagen bearbeitet.","successInfo2":"Notieren Sie sich die generierte Protokollnummer, damit Sie den Fortschritt und die Antworten auf Ihre Anfrage einsehen können. Wenn Sie eine E-Mail-Adresse angegeben haben, überprüfen Sie Ihren Posteingang.","information":"Kontaktinformationen","attachments":"Anhänge","attachmentInfo":"Auf diesem Bildschirm können Sie Dateien anhängen, die die Gründe für Ihre Anfrage belegen. Zum Abschließen klicken Sie auf Abschließen.","fields":{"text":"Schreiben Sie Ihre Anfrage","termsAccepted":"Ich erkläre, dass ich diesen Bericht in gutem Glauben einreiche.","classification":{"nature":"Art der Mitteilung"},"relatedInfo":"Geben Sie die Protokollnummer oder das Datum, die Abteilung und den Namen des Sachbearbeiters an, der mit Ihrer ungelösten Anfrage verbunden ist"},"fieldsDesc":{"text":"Beschreiben Sie Ihre Anfrage so detailliert wie möglich."},"confirmation":"Bestätigung","termsInfo":"Ich erkläre mein Einverständnis zur Verwendung der bereitgestellten personenbezogenen Daten zum ausschließlichen Zweck der Lösung und Bearbeitung dieser Beschwerde, unter der Bedingung, dass der Datenschutz gewährleistet wird. Ich erkläre ferner, dass mir bekannt ist, dass meine Daten für einen Zeitraum von 05 (fünf) Jahren archiviert bleiben, gemäß den gesetzlichen und regulatorischen Bestimmungen, die für die Ombudsfunktion gelten."},"task":{"info":"Informationen","description":"Beschreibung","response":"Antwort","dueDate":"Fälligkeitsdatum","fields":{"text":"Schreiben Sie Ihre Antwort"},"fieldsDesc":{"text":"Beschreiben Sie Ihre Antwort so detailliert wie möglich."},"attachments":"Anhänge","attachmentInfo":"Hängen Sie alle Dateien an, die Sie für notwendig halten, um Ihre Antwort zu vervollständigen.","send":"Senden","success":"Antwort erfolgreich gesendet!","expired":"Verfahren abgeschlossen!"},"classification":{"businessGroup":"Mit den Fakten verbundenes Unternehmen","nature":"Berichtstyp","reportingAgent":"Wählen Sie Ihre Zugehörigkeit zur Organisation","origin":"Kommunikationsursprung","level":"Klassifizierung","responsibleDepartment":"Für die Bearbeitung zuständiger Bereich","involvedDepartment":"Betroffene Abteilung","businessUnit":"Einheit/Standort/Filiale","relatedProject":"Vertrag/Projekt","ombudsmanNature":"Art der Mitteilung","ombudsmanService":"Beanstandeter Dienst"},"complaint":{"title":"Meldung über das Internet einreichen","titleAlt":"Mitteilung über das Internet einreichen","introduction":"Um eine Meldung über diesen Kanal einzureichen, können Sie sich identifizieren oder anonym bleiben. Wenn Sie sich identifizieren, garantiert der Prüfungsausschuss von {0} den Schutz und die Vertraulichkeit Ihrer Informationen gemäß dem Gesetz. Notieren Sie sich immer das generierte Protokoll, damit Sie den Fortschritt Ihrer Mitteilung verfolgen können.","introductionAlt":"Um eine Mitteilung über diesen Kanal einzureichen, können Sie sich identifizieren oder anonym bleiben. Wenn Sie sich identifizieren, garantiert der Prüfungsausschuss von {0} den Schutz und die Vertraulichkeit Ihrer Informationen gemäß dem Gesetz. Notieren Sie sich immer das generierte Protokoll, damit Sie den Fortschritt Ihrer Mitteilung verfolgen können.","instruction":"Füllen Sie das folgende Formular mit so vielen Informationen und Details wie möglich aus, um die Untersuchung und Überprüfung der gemeldeten Fakten zu erleichtern. Lassen Sie Informationen, die Ihnen nicht bekannt sind, leer. Sie können auch Dateien anhängen, die das Ereignis belegen.","information":"Informationen","files":"Dateien/Beweise","confirmation":"Bestätigung","back":"Zurück","next":"Weiter","finish":"Abschließen","filesInstruction":"Auf diesem Bildschirm können Sie Dateien anhängen, die zur Klärung der Fakten beitragen (nicht verpflichtend). Um fortzufahren, klicken Sie auf Weiter.","success":"Meldung erfolgreich gesendet!","successInfo":"Ihre Mitteilung wurde empfangen und wird bearbeitet. Notieren Sie sich die generierte Protokollnummer, damit Sie den Fortschritt der Untersuchung verfolgen können.","termsInfo":"Um dieses Verfahren abzuschließen, müssen Sie den unten stehenden Bedingungen zustimmen. Wählen Sie einfach aus und klicken Sie dann auf „Abschließen\\".","fields":{"anonymous":"Möchten Sie sich identifizieren?","termsAccepted":"Ich erkläre, dass ich diesen Bericht in gutem Glauben einreiche.","previousProtocol":{"desc":"Steht der gemeldete Sachverhalt in Zusammenhang mit einer früheren Meldung?"},"dataConsentAccepted":"Ich erkläre mein Einverständnis zur Verwendung der bereitgestellten personenbezogenen Daten zum ausschließlichen Zweck der Untersuchung dieser Meldung, unter der Bedingung, dass die Daten vom Untersuchungsausschuss vertraulich behandelt werden.","text":{"label":"Schreiben Sie Ihre Meldung mit so vielen Informationen wie möglich.","desc":"Beschreiben Sie so detailliert wie möglich, was passiert ist, und nennen Sie die beteiligten Personen und wie die Ereignisse stattfanden."},"date":{"label":"Kennen Sie das Datum der Fakten?","desc":"Geben Sie das Datum an, auch wenn es ungefähr ist, und ob die Fakten noch andauern."},"city":{"label":"Stadt"},"communication":{"label":"Schreiben Sie Ihre Mitteilung mit so vielen Informationen wie möglich."},"location":{"label":"Wo haben sich die Fakten ereignet?","desc":"Geben Sie den Ort an, an dem sich die Ereignisse zugetragen haben, einschließlich Stadt, Einheit und Abteilung."},"knowAbout":{"label":"Wie haben Sie von den Fakten erfahren?"},"witnesses":{"label":"Kennen Sie jemanden, der die Fakten bezeugt/miterlebt hat oder Kenntnis davon hat? Wenn ja, nennen Sie die Namen."},"financialInfo":{"label":"Gab es finanzielle Schäden? Können Sie den Wert angeben?","desc":"Geben Sie die Ihnen bekannten Schadensbeträge an"}}},"mfu":{"attachmentList":"Anhangsliste","editImage":"Bild bearbeiten","dragNdrop":"Dateien zum Anhängen ablegen","preview":"Vorschau","name":"Name","size":"Größe","action":"Aktion","noImage":"Kein Bild","edit":"Bearbeiten","remove":"Entfernen","dragNdropHere":"Dateien hier ablegen zum Anhängen","or":"oder","selectFiles":"Dateien auswählen","editFile":"Datei bearbeiten","filenameField":"Dateinamen eingeben","image":"Bild","zoomIn":"Vergrößern","zoomOut":"Verkleinern","rotate":"Drehen","flipH":"Horizontal spiegeln","flipV":"Vertikal spiegeln","reset":"Zurücksetzen","apply":"Anwenden","cancel":"Abbrechen","save":"Speichern","errors":{"size":"Die Größe muss größer als 1 KB und kleiner als 10 MB sein","extension":"Ungültige Erweiterung","timeout":"Zeit überschritten","abort":"Abgebrochen","network":"Netzwerkfehler","server":"Serverfehler","denied":"Verweigert","edit":"Bearbeitung...","unknown":"Unbekannter Fehler","unsupported":"Ihr Browser unterstützt diese Funktion nicht"}},"router":{"Home":"Startseite","Report":"Melden","ReportAlt":"Melden","Questions and Suggestions":"Fragen und Anregungen","Follow up":"Verfolgen","Ombudsman":"Ombudsstelle","Information":"Informationen","Committee":"Ausschuss","Channel Policy":"Kanalrichtlinie","Code of Ethics":"Verhaltenskodex","Compliance":"Compliance","Channel Video":"Kanalvideo","Data Subject Access Request":"Personenbezogene Daten"},"martinelli":{"hero":{"badge":"100% ANONYME MELDUNGEN","title":"Vertraulichkeit und Unparteilichkeit.","titleSmall":"Gemeinsam.","description":"{0} verfügt über ein unabhängiges Juristenteam, das bereit ist, Ihre Meldung vertraulich, anonym, sicher und ethisch entgegenzunehmen.","reportBtn":"Meldung einreichen","howItWorks":"Wie funktioniert es?"},"followUp":{"badge":"VERFOLGEN SIE IHRE MELDUNG","title":"Um nachzuschauen, suchen Sie nach der Protokollnummer der eingereichten Meldung:","placeholder":"Geben Sie die Protokollnummer ein","searchBtn":"Suchen"},"organization":{"title":"Für eine","titleHighlight":"ethischere","titleEnd":"Organisation","description":"Der geeignete Kanal, über den jede Person, intern oder extern, Verdachtsfälle von Korruption, Betrug und andere im Gesetz Nr. 12.846/2013 vorgesehene Fälle, Belästigungshandlungen gemäß Gesetz 14.457/2022 sowie andere Handlungen melden kann, die unserem Engagement für Ethik und Integrität widersprechen. Wir zählen auf Sie!"},"features":{"confidentiality":{"title":"Vertraulichkeit","desc":"Ihre Meldungen sind vertraulich und werden ausschließlich von Martinelli Advogados geprüft"},"nonRetaliation":{"title":"Keine Vergeltung","desc":"Wir verbieten jede Art von Vergeltung gegen Meldende und Beteiligte an Untersuchungen"},"tracking":{"title":"Nachverfolgung","desc":"Nach Einreichung einer Meldung können Sie den Fortschritt über dieses Portal verfolgen"},"feedback":{"title":"Rückmeldung","desc":"Die Meldung kann begründet sein oder nicht, aber Sie erhalten immer eine Rückmeldung dazu."}},"process":{"title":"Einfacher, klarer und völlig","titleSmall":"unparteiischer","titleEnd":"Prozess.","description":"Um Unparteilichkeit und Vertraulichkeit zu gewährleisten, werden Ihre Meldungen von Martinelli Advogados, einer auf Integrität und Unternehmensethik spezialisierten Anwaltskanzlei, empfangen und geprüft","details":"Die Berichte werden einer rechtlichen Analyse unterzogen, um Interessenkonflikte oder Beeinträchtigungen der Unparteilichkeit beim Empfang der Meldungen zu vermeiden. Nach der Analyse werden sie mit den entsprechenden Anweisungen nur an die notwendigen Personen in der Organisation weitergeleitet","check1":"Ihre Meldung wird ohne jegliche Identitäts- oder IP-Aufzeichnung gesendet","check2":"Der Prozess wird von einem externen und unabhängigen Team geprüft","check3":"Sie verfolgen den Prozess Schritt für Schritt","reportBtn":"Meldung einreichen"},"documents":{"title":"Wichtige","titleSmall":"Lektüre","description":"Hier finden Sie den Verhaltenskodex und die wichtigsten Dokumente, die beschreiben, wie die Meldung empfangen wird, interne Verfahren und mögliche Konsequenzen.","download":"Datei herunterladen"},"container":{"documents":"Dokumente","help":"Hilfe","admin":"Verwaltung","loading":"Wird geladen..."},"faq":{"sectionTitle":"Fragen zum Meldeportal?","sectionTitleHighlight":"Fragen","q1":"Wozu dient dieser Kanal?","a1":"Dieser Kanal dient dazu, auf sichere und, wenn gewünscht, anonyme Weise jede Handlung von Mitarbeitern, Lieferanten, Dienstleistern zu melden, die gegen Gesetze, den Verhaltenskodex, die internen Normen und Richtlinien der Institution verstößt.","q2":"Wer kann den Kanal nutzen?","a2":"Jede Person, die Kenntnis von Verstößen gegen Gesetze, den Verhaltenskodex, interne Normen oder Richtlinien der Institution hat.","q3":"Was kann über den Kanal gemeldet werden?","a3":"Der Begriff der Meldung umfasst Themen wie Verdacht oder Gewissheit von Korruption, Belästigung, Begünstigung von Dritten oder Lieferanten, Diebstahl, Betrug, Unterschlagung und verschiedene andere Verhaltensweisen, die gegen das Gesetz, den Verhaltenskodex, interne Normen oder Richtlinien der Institution verstoßen und sich auf Mitarbeiter, Lieferanten, Dienstleister und jede Person beziehen, die im Namen der Institution handelt.","q4":"Wer erhält meine Meldung?","a4":"Die Meldung wird von einem qualifizierten Team von Martinelli Advogados empfangen und nach der Prüfung an den für die Untersuchung zuständigen Ausschuss weitergeleitet. Alle am Empfangs- und Untersuchungsprozess Beteiligten.","q5":"Muss ich Beweise vorlegen?","a5":"Es ist nicht unbedingt erforderlich, aber die Vorlage oder Angabe von Elementen, die den gemeldeten Sachverhalt belegen, kann für die Untersuchung und die aufgrund der Meldung zu ergreifenden Maßnahmen entscheidend sein."},"footer":{"title":"Martinelli Advogados","contact":"Kontakt aufnehmen","copyright":"© 2023 Martinelli. Alle Rechte vorbehalten."}}}')},b90e:function(e){e.exports=JSON.parse('{"labels":{"protocol":"协议编号","home":"首页","search":"查询","response":"补充信息和回复。","responseDesc":"请使用此空间提供补充信息、回答问题或与我们的团队互动。您的配合对完成程序至关重要。","sendResponse":"发送回复","insertNewInformation":"向您的协议中添加新信息","insertNewInformationDesc":"您可以使用此字段向您的协议添加信息","sendInformation":"发送信息","newSearch":"新查询","back":"返回","next":"下一步","finish":"完成","yes":"是","no":"否"},"home":{"title":"{0} 举报渠道","introductionText":"您正处于一个安全的环境中，该环境托管在 {0} 之外，由 Conformità Gestão de Compliance 管理。我们提供独立的环境以确保投诉的接收和处理，以及信息的保密性。","instructionText":"该渠道面向 {0} 的内部人员。您可以通过举报违反规则和/或法律的情况、犯罪行为、欺诈、骚扰、歧视以及任何损害 {0} 或人员尊严的情况，协助创建更加道德的环境。您的协助对实现日益道德的环境至关重要。我们感谢您的态度。要跟踪您的举报进展，请点击下方的\\"跟踪\\"。","phoneService":"您可以通过点击下方的举报按钮在网上提交举报。如果您选择通过电话提交举报，可以拨打免费电话 {0}。","btn":{"report":"举报","communicate":"举报","qas":"问题和建议","followup":"跟踪","ombudsman":"监察","dsar":"个人数据"}},"followup":{"title":"跟踪协议","instruction":"要跟踪您通讯的进展，请在下方输入生成的协议编号或内部流程编号。","resultTitle":"该协议的已注册跟踪记录","receivedDay":"需求接收日期","receivedTime":"时间","successResponse":"回复发送成功！"},"qas":{"title":"问题或建议提交表","introduction":"如果您有关于道德、诚信、指导方针和内部流程或其他相关主题的问题或建议，可以使用此渠道。问题或建议的内容将由主管部门评估，您将在合理时间内收到回复。您可以选择表明身份或保持匿名。我们将保证您信息的保护。最后，请记下生成的协议编号，以便查询您需求的回复。","instruction":"请尽可能详细地填写以下表格，以便负责团队理解。继续操作后，您可以附加文件。","success":"问题/建议发送成功！","successInfo1":"您的请求已收到，将在合理时间内处理。","successInfo2":"请记下生成的协议编号，以便查询您请求的回复。","information":"信息","attachments":"附件","attachmentInfo":"在此页面，您可以附加支持您问题或建议理由的文件。要完成，请点击完成。","fields":{"anonymous":"您想表明身份吗？","relation":"您与 {0} 的关系是什么？","text":"写下您的问题/建议"},"fieldsDesc":{"text":"请尽可能详细地描述您的问题/建议。如果可能，请注明您所指的区域/部门"}},"dsar":{"title":"个人数据相关请求","introduction":"通过此表格，数据主体或法定监护人/代表可以提交个人数据相关请求，这些请求将根据《通用数据保护法》的指导方针进行处理。我们通过此环境促进用户对其权利的访问，并允许提交、记录和监控其请求。本页面和本门户其他页面收集的数据将仅用于满足和记录数据主体的请求/需求。","instruction":"请尽可能详细地填写以下表格，以便负责团队理解。提供电子邮件后，您将收到协议证明和后续通知。继续操作后，您可以附加文件。","success":"请求发送成功！","successInfo1":"您的请求已收到，将在15天内处理。","successInfo2":"请记下生成的协议编号，以便查看您请求的进展和回复。如果您已输入电子邮件，请检查您的收件箱。","information":"联系信息","attachments":"附件","attachmentInfo":"在此页面，您可以附加支持您请求理由的文件。要完成，请点击完成。","fields":{"text":"写下您的请求"},"fieldsDesc":{"text":"请尽可能详细地描述您的请求。"}},"ombudsman":{"title":"监察","introduction":"监察渠道应作为最后手段使用。它接收其他组织部门未解决的请求。因此，在联系监察部门之前，务必先尝试与客户服务团队解决问题。","instruction":"请尽可能详细地填写以下表格，以便负责团队理解。提供电子邮件后，您将收到协议证明和后续通知。继续操作后，您可以附加文件。","success":"请求发送成功！","successInfo1":"您的请求已收到，将在10天内处理。","successInfo2":"请记下生成的协议编号，以便查看您请求的进展和回复。如果您已输入电子邮件，请检查您的收件箱。","information":"联系信息","attachments":"附件","attachmentInfo":"在此页面，您可以附加支持您请求理由的文件。要完成，请点击完成。","fields":{"text":"写下您的请求","termsAccepted":"我声明我提交此举报是出于善意。","classification":{"nature":"通讯性质"},"relatedInfo":"请提供与您未解决需求相关的协议编号或日期、部门和服务人员姓名"},"fieldsDesc":{"text":"请尽可能详细地描述您的请求。"},"confirmation":"确认","termsInfo":"我同意所提供的个人数据仅用于解决和处理此投诉，并保证其隐私。我还声明我知道我的数据将按照适用于监察职能的法律和法规规定存档五（5）年。"},"task":{"info":"信息","description":"描述","response":"回复","dueDate":"截止日期","fields":{"text":"写下您的回复"},"fieldsDesc":{"text":"请尽可能详细地描述您的回复。"},"attachments":"附件","attachmentInfo":"附加您认为完成回复所必需的任何文件。","send":"发送","success":"回复发送成功！","expired":"程序已完成！"},"classification":{"businessGroup":"与事实相关的公司","nature":"举报类型","reportingAgent":"选择您与组织的关系","origin":"通讯来源","level":"级别","responsibleDepartment":"负责处理的部门","involvedDepartment":"发生部门","businessUnit":"单位/岗位/分支","relatedProject":"合同/项目","ombudsmanNature":"通讯性质","ombudsmanService":"被投诉服务"},"complaint":{"title":"在线举报","titleAlt":"在线举报","introduction":"通过此渠道提交举报时，您可以选择表明身份或保持匿名。如果您选择表明身份，{0} 验证委员会将依法保证您信息的保护和保密。请务必记下将生成的协议编号，以便跟踪您通讯的进展。","introductionAlt":"通过此渠道提交举报时，您可以选择表明身份或保持匿名。如果您选择表明身份，{0} 验证委员会将依法保证您信息的保护和保密。请务必记下将生成的协议编号，以便跟踪您通讯的进展。","instruction":"请尽可能详细地填写以下表格，以便调查和核实所报告的事实，将您不了解的信息留空。您还可以附加显示事件的文件。","information":"信息","files":"档案/证据","confirmation":"确认","back":"返回","next":"下一步","finish":"完成","filesInstruction":"在此页面，您可以附加有助于澄清事实的文件（非必填）。要继续，请点击下一步。","success":"举报发送成功！","successInfo":"您的通讯已收到并将被处理。请记下生成的协议编号，以便跟踪调查进展。","termsInfo":"要完成此程序，您必须同意以下条件。只需选择然后点击\\"完成\\"。","fields":{"anonymous":"您想表明身份吗？","termsAccepted":"我声明我提交此举报是出于善意。","previousProtocol":{"desc":"所举报的事实是否与之前的投诉有关？"},"dataConsentAccepted":"我同意所提供的个人数据仅用于调查此投诉，并由调查委员会保密。","text":{"label":"请尽可能详细地写下您的举报。","desc":"请尽可能详细地描述发生了什么，指明涉及的人员以及事件如何发生。"},"date":{"label":"您知道事实的日期吗？","desc":"请提供日期，即使是大概日期，以及事实是否仍在发生。"},"city":{"label":"城市"},"communication":{"label":"请尽可能详细地写下您的通讯。"},"location":{"label":"事实发生在哪里？","desc":"请提供事件发生地，包括城市、单位和部门。"},"knowAbout":{"label":"您是如何得知这些事实的？"},"witnesses":{"label":"您是否知道有人目击/见证了这些事实，或了解相关情况？如果是，请提供姓名。"},"financialInfo":{"label":"是否有经济损失？您能提供金额吗？","desc":"请注明您所知的损失金额"}}},"mfu":{"attachmentList":"附件列表","editImage":"编辑图片","dragNdrop":"拖放文件以附加","preview":"预览","name":"名称","size":"大小","action":"操作","noImage":"无图片","edit":"编辑","remove":"删除","dragNdropHere":"将文件拖放到此处以附加","or":"或","selectFiles":"选择文件","editFile":"编辑文件","filenameField":"输入文件名","image":"图片","zoomIn":"放大","zoomOut":"缩小","rotate":"旋转","flipH":"水平翻转","flipV":"垂直翻转","reset":"重置","apply":"应用","cancel":"取消","save":"保存","errors":{"size":"大小必须大于1 KB且小于10 MB","extension":"无效扩展名","timeout":"超时","abort":"已中止","network":"网络错误","server":"服务器错误","denied":"已拒绝","edit":"编辑中...","unknown":"未知错误","unsupported":"您的浏览器不支持此功能"}},"router":{"Home":"首页","Report":"举报","ReportAlt":"举报","Questions and Suggestions":"问题和建议","Follow up":"跟踪","Ombudsman":"监察","Information":"信息","Committee":"委员会","Channel Policy":"渠道政策","Code of Ethics":"道德准则","Compliance":"合规","Channel Video":"渠道视频","Data Subject Access Request":"个人数据"},"martinelli":{"hero":{"badge":"100% 匿名举报","title":"保密与公正。","titleSmall":"携手共进。","description":"{0} 拥有独立的法律团队，随时准备以保密、匿名、安全和道德的方式接收您的举报。","reportBtn":"提交举报","howItWorks":"如何运作？"},"followUp":{"badge":"跟踪您的举报","title":"要查询，请搜索已提交举报的协议编号：","placeholder":"输入协议编号","searchBtn":"搜索"},"organization":{"title":"为了更加","titleHighlight":"道德","titleEnd":"的组织","description":"任何内部或外部人员举报涉嫌腐败、欺诈及第12,846/2013号法律规定的其他情况、第14,457/2022号法律规定的骚扰行为，以及其他违反我们道德和诚信承诺的行为的适当渠道。我们需要您的参与！"},"features":{"confidentiality":{"title":"保密性","desc":"您的举报是保密的，仅由Martinelli Advogados审查"},"nonRetaliation":{"title":"不报复","desc":"我们禁止对举报人和调查参与者的任何形式的报复"},"tracking":{"title":"跟踪","desc":"提交举报后，您可以通过此门户跟踪进展"},"feedback":{"title":"反馈","desc":"举报可能成立也可能不成立，但您始终会收到相关反馈。"}},"process":{"title":"简单、清晰且完全","titleSmall":"公正","titleEnd":"的流程。","description":"为确保公正性和保密性，您的举报由Martinelli Advogados接收和审查，这是一家专注于诚信和企业道德的律师事务所","details":"举报经过法律分析，以避免接收举报时的利益冲突或公正性缺失。分析后，仅向组织中必要的人员转发并附上适当的指示","check1":"您的举报在发送时不记录任何身份或IP信息","check2":"该流程由外部独立团队审计","check3":"您可以逐步跟踪流程","reportBtn":"提交举报"},"documents":{"title":"重要","titleSmall":"阅读","description":"在这里您可以找到道德准则和详细说明举报接收方式、内部程序和可能后果的关键文件。","download":"下载文件"},"container":{"documents":"文件","help":"帮助","admin":"管理","loading":"加载中..."},"faq":{"sectionTitle":"关于举报门户的","sectionTitleHighlight":"问题","q1":"此渠道的用途是什么？","a1":"此渠道用于安全地（如有需要可匿名）举报员工、供应商、服务提供商违反法律、行为准则、机构内部规范和政策的任何行为。","q2":"谁可以使用此渠道？","a2":"任何了解违反法律、行为准则、机构内部规范或政策情况的人。","q3":"可以在渠道上举报什么？","a3":"举报范围涵盖涉嫌或确认的腐败行为、骚扰、偏袒第三方或供应商、盗窃、欺诈、挪用公款以及其他违反法律、行为准则、机构内部规范或政策的各种行为，涉及员工、供应商、服务提供商以及代表机构行事的任何人。","q4":"谁将收到我的举报？","a4":"举报将由Martinelli Advogados的专业团队接收，经审查后转交给负责调查举报的委员会。所有参与接收和调查过程的人员。","q5":"我需要提供证据吗？","a5":"不是必须的，但提供或指出证明所举报事实发生的证据可能对调查和因举报而采取的措施起决定性作用。"},"footer":{"title":"Martinelli Advogados","contact":"联系我们","copyright":"© 2023 Martinelli。保留所有权利。"}}}')},ba2c:function(e,a,n){"use strict";n.d(a,"d",(function(){return t})),n.d(a,"i",(function(){return o})),n.d(a,"b",(function(){return r})),n.d(a,"e",(function(){return s})),n.d(a,"n",(function(){return c})),n.d(a,"j",(function(){return d})),n.d(a,"k",(function(){return l})),n.d(a,"a",(function(){return u})),n.d(a,"m",(function(){return m})),n.d(a,"h",(function(){return p})),n.d(a,"o",(function(){return f})),n.d(a,"f",(function(){return h})),n.d(a,"l",(function(){return g})),n.d(a,"c",(function(){return b})),n.d(a,"g",(function(){return k}));n("862d");var i=n("3e76");function t(e){return Object(i["a"])({url:e?"/portal/".concat(e,"/info"):"/portal/info",method:"get"})}function o(e,a){return Object(i["a"])({url:"/complaints/".concat(e),method:"post",data:{complaint:a}})}function r(e){return Object(i["a"])({url:"/companies/".concat(e,"/business-groups"),method:"get"})}function s(e){return Object(i["a"])({url:"/companies/".concat(e,"/levels"),method:"get"})}function c(e,a){return Object(i["a"])({url:"/qas/".concat(e),method:"post",data:{qas:a}})}function d(e,a){return Object(i["a"])({url:"/dsar/".concat(e),method:"post",data:{dsar:a}})}function l(e,a){return Object(i["a"])({url:"/ombudsman/".concat(e),method:"post",data:{record:a}})}function u(e,a){return Object(i["a"])({url:"/protocol/".concat(e,"/").concat(a),method:"get"})}function m(e,a,n){return Object(i["a"])({url:"/protocol/".concat(e,"/").concat(a,"/response"),method:"post",data:{response:n}})}function p(e){return Object(i["a"])({url:"/events/".concat(e,"/"),method:"get"})}function f(e,a){return Object(i["a"])({url:"/events/".concat(e,"/"),method:"post",data:{response:a}})}function h(e){return Object(i["a"])({url:"/ombudsman-events/".concat(e,"/"),method:"get"})}function g(e,a){return Object(i["a"])({url:"/ombudsman-events/".concat(e,"/"),method:"post",data:{response:a}})}function b(e,a,n){return Object(i["a"])({url:"/companies/".concat(e,"/classifications/type/").concat(a,"?group=").concat(n),method:"get"})}function k(e){return Object(i["a"])({url:"/companies/".concat(e,"/classifications"),method:"get"})}},ccd5:function(e){e.exports=JSON.parse('{"labels":{"protocol":"Protokol","home":"Beranda","search":"Cari","response":"Informasi tambahan dan jawaban.","responseDesc":"Gunakan ruang ini untuk memberikan informasi tambahan, menjawab pertanyaan, atau berinteraksi dengan tim kami. Kerja sama Anda sangat penting untuk penyelesaian prosedur.","sendResponse":"Kirim Balasan","insertNewInformation":"Masukkan informasi baru ke protokol Anda","insertNewInformationDesc":"Anda dapat menggunakan kolom ini untuk menambahkan informasi ke protokol Anda","sendInformation":"Kirim Informasi","newSearch":"Pencarian Baru","back":"Kembali","next":"Selanjutnya","finish":"Selesai","yes":"Ya","no":"Tidak"},"home":{"title":"Saluran pelaporan {0}","introductionText":"Anda berada di lingkungan yang aman, dihosting di luar {0}, dikelola oleh Conformità Gestão de Compliance. Kami menyediakan lingkungan independen untuk memastikan penerimaan dan pemrosesan pengaduan, serta kerahasiaan informasi.","instructionText":"Saluran ini ditujukan untuk audiens internal {0}. Anda dapat berkontribusi untuk menciptakan lingkungan yang lebih etis dengan melaporkan situasi pelanggaran aturan dan/atau hukum, tindak kriminal, penipuan, pelecehan, diskriminasi, dan situasi lain yang merugikan {0} atau integritas orang. Kerja sama Anda sangat penting untuk mencapai lingkungan yang semakin etis. Kami semua berterima kasih atas sikap Anda. Untuk mengikuti perkembangan laporan Anda, klik \\"tindak lanjut\\" di bawah.","phoneService":"Anda dapat mengirim laporan melalui internet dengan mengklik tombol laporan di bawah. Jika Anda memilih untuk mendaftarkan laporan melalui telepon, Anda dapat menghubungi nomor bebas pulsa {0}.","btn":{"report":"Laporan","communicate":"Laporan","qas":"Pertanyaan dan Saran","followup":"Tindak Lanjut","ombudsman":"Ombudsman","dsar":"Data Pribadi"}},"followup":{"title":"Ikuti Protokol","instruction":"Untuk mengikuti perkembangan komunikasi Anda, silakan masukkan nomor protokol yang dihasilkan atau nomor proses internal di bawah.","resultTitle":"Pendampingan terdaftar untuk protokol","receivedDay":"Permintaan diterima pada","receivedTime":"pukul","successResponse":"Balasan berhasil dikirim!"},"qas":{"title":"Formulir pengiriman pertanyaan atau saran","introduction":"Jika Anda memiliki pertanyaan atau saran terkait etika, integritas, pedoman dan proses internal, atau topik relevan lainnya, Anda dapat menggunakan saluran ini. Isi pertanyaan atau saran akan dievaluasi oleh area yang berwenang dan Anda akan menerima tanggapan dalam waktu yang wajar. Silakan identifikasi diri Anda atau tetap anonim. Kami akan menjamin perlindungan informasi Anda. Di akhir, catat nomor protokol yang dihasilkan untuk memeriksa jawaban atas permintaan Anda.","instruction":"Isi formulir di bawah dengan informasi dan detail selengkap mungkin, untuk memudahkan pemahaman tim yang bertanggung jawab. Saat melanjutkan, Anda dapat melampirkan file.","success":"Pertanyaan/saran berhasil dikirim!","successInfo1":"Klaim Anda telah diterima dan akan ditangani dalam waktu yang wajar.","successInfo2":"Catat protokol yang dihasilkan agar Anda dapat memeriksa tanggapan atas permintaan Anda.","information":"Informasi","attachments":"Lampiran","attachmentInfo":"Di layar ini Anda dapat melampirkan file yang mendukung alasan pertanyaan atau saran Anda. Untuk menyelesaikan, klik selesai.","fields":{"anonymous":"Apakah Anda ingin mengidentifikasi diri?","relation":"Apa hubungan Anda dengan {0}?","text":"Tulis pertanyaan/saran Anda"},"fieldsDesc":{"text":"Jelaskan pertanyaan/saran Anda sedetail mungkin. Jika memungkinkan, sebutkan area/sektor yang Anda maksud"}},"dsar":{"title":"Permintaan Terkait Data Pribadi","introduction":"Melalui formulir ini, subjek data atau wali/perwakilan hukum dapat mengirim permintaan terkait data pribadi yang akan ditangani sesuai dengan pedoman Undang-Undang Perlindungan Data Umum. Kami berupaya melalui lingkungan ini untuk memfasilitasi akses pengguna terhadap hak-hak mereka serta memungkinkan pengajuan, pencatatan, dan pemantauan permintaan mereka. Data yang dikumpulkan di halaman ini dan halaman lain portal ini akan diproses semata-mata untuk memenuhi dan mencatat permintaan/kebutuhan subjek data.","instruction":"Isi formulir di bawah dengan informasi dan detail selengkap mungkin, untuk memudahkan pemahaman tim yang bertanggung jawab. Dengan memberikan email, Anda akan menerima bukti protokol dan notifikasi tindak lanjut. Saat melanjutkan, Anda dapat melampirkan file.","success":"Permintaan berhasil dikirim!","successInfo1":"Permintaan Anda telah diterima dan akan ditangani dalam 15 hari.","successInfo2":"Catat protokol yang dihasilkan agar Anda dapat melihat perkembangan dan tanggapan atas permintaan Anda. Jika Anda telah memasukkan email, periksa kotak masuk Anda.","information":"Informasi Kontak","attachments":"Lampiran","attachmentInfo":"Di layar ini Anda dapat melampirkan file yang mendukung alasan permintaan Anda. Untuk menyelesaikan, klik selesai.","fields":{"text":"Tulis permintaan Anda"},"fieldsDesc":{"text":"Jelaskan permintaan Anda sedetail mungkin."}},"ombudsman":{"title":"Ombudsman","introduction":"Saluran ombudsman harus digunakan sebagai upaya terakhir. Saluran ini menerima permintaan yang belum diselesaikan oleh area lain dalam organisasi. Oleh karena itu, sebelum menghubungi ombudsman, penting untuk mencoba menyelesaikan masalah dengan tim layanan pelanggan.","instruction":"Isi formulir di bawah dengan informasi dan detail selengkap mungkin, untuk memudahkan pemahaman tim yang bertanggung jawab. Dengan memasukkan email, Anda akan menerima bukti protokol dan notifikasi tindak lanjut. Saat melanjutkan, Anda dapat melampirkan file.","success":"Permintaan berhasil dikirim!","successInfo1":"Permintaan Anda telah diterima dan akan ditangani dalam 10 hari.","successInfo2":"Catat protokol yang dihasilkan agar Anda dapat melihat perkembangan dan tanggapan atas permintaan Anda. Jika Anda telah memasukkan email, periksa kotak masuk Anda.","information":"Informasi Kontak","attachments":"Lampiran","attachmentInfo":"Di layar ini Anda dapat melampirkan file yang mendukung alasan permintaan Anda. Untuk menyelesaikan, klik selesai.","fields":{"text":"Tulis permintaan Anda","termsAccepted":"Saya menyatakan bahwa saya bertindak dengan itikad baik dalam menyampaikan laporan ini.","classification":{"nature":"Sifat Komunikasi"},"relatedInfo":"Berikan nomor protokol atau tanggal, sektor, dan nama petugas terkait permintaan Anda yang belum terselesaikan"},"fieldsDesc":{"text":"Jelaskan permintaan Anda sedetail mungkin."},"confirmation":"Konfirmasi","termsInfo":"Saya menyatakan persetujuan saya atas penggunaan data pribadi yang diberikan untuk tujuan eksklusif penyelesaian dan pemrosesan pengaduan ini, dengan ketentuan bahwa privasi dijamin. Saya juga menyatakan bahwa saya menyadari data saya akan disimpan selama periode 05 (lima) tahun, sesuai dengan ketentuan hukum dan peraturan yang berlaku untuk fungsi Ombudsman."},"task":{"info":"Informasi","description":"Deskripsi","response":"Tanggapan","dueDate":"Tenggat waktu","fields":{"text":"Tulis tanggapan Anda"},"fieldsDesc":{"text":"Jelaskan tanggapan Anda sedetail mungkin."},"attachments":"Lampiran","attachmentInfo":"Lampirkan file apa pun yang Anda anggap perlu untuk melengkapi tanggapan Anda.","send":"Kirim","success":"Tanggapan berhasil dikirim!","expired":"Prosedur selesai!"},"classification":{"businessGroup":"Perusahaan terkait fakta","nature":"Jenis laporan","reportingAgent":"Pilih afiliasi Anda dengan organisasi","origin":"Asal Komunikasi","level":"Peringkat","responsibleDepartment":"Area yang bertanggung jawab untuk pemrosesan","involvedDepartment":"Sektor Kejadian","businessUnit":"Unit/Pos/Cabang","relatedProject":"Kontrak/Proyek","ombudsmanNature":"Sifat Komunikasi","ombudsmanService":"Layanan yang Diadukan"},"complaint":{"title":"Laporan melalui internet","titleAlt":"Laporan melalui internet","introduction":"Untuk mengirim laporan melalui saluran ini, Anda dapat mengidentifikasi diri atau tetap anonim. Jika Anda memilih untuk mengidentifikasi diri, komite verifikasi {0} akan menjamin perlindungan dan kerahasiaan informasi Anda sesuai dengan hukum. Selalu catat protokol yang akan dihasilkan, agar Anda dapat memantau perkembangan komunikasi Anda.","introductionAlt":"Untuk mengirim laporan melalui saluran ini, Anda dapat mengidentifikasi diri atau tetap anonim. Jika Anda memilih untuk mengidentifikasi diri, komite verifikasi {0} akan menjamin perlindungan dan kerahasiaan informasi Anda sesuai dengan hukum. Selalu catat protokol yang akan dihasilkan, agar Anda dapat memantau perkembangan komunikasi Anda.","instruction":"Isi formulir di bawah dengan informasi dan detail selengkap mungkin, untuk memudahkan investigasi dan verifikasi fakta yang dilaporkan, biarkan kosong informasi yang tidak Anda ketahui. Anda juga dapat melampirkan file yang menunjukkan kejadian.","information":"Informasi","files":"Arsip/Bukti","confirmation":"Konfirmasi","back":"Kembali","next":"Selanjutnya","finish":"Selesai","filesInstruction":"Di layar ini Anda dapat melampirkan file yang berkontribusi untuk memperjelas fakta (tidak wajib). Untuk melanjutkan, klik selanjutnya.","success":"Laporan berhasil dikirim!","successInfo":"Komunikasi Anda telah diterima dan akan diproses. Catat protokol yang dihasilkan agar Anda dapat mengikuti perkembangan investigasi.","termsInfo":"Untuk menyelesaikan prosedur ini, Anda harus menyetujui ketentuan di bawah ini. Cukup pilih lalu klik \\"Selesai\\".","fields":{"anonymous":"Apakah Anda ingin mengidentifikasi diri?","termsAccepted":"Saya menyatakan bahwa saya bertindak dengan itikad baik dalam menyampaikan laporan ini.","previousProtocol":{"desc":"Apakah fakta yang dilaporkan terkait dengan pengaduan sebelumnya?"},"dataConsentAccepted":"Saya menyatakan persetujuan saya atas penggunaan data pribadi yang diberikan, semata-mata untuk tujuan penyelidikan pengaduan ini, dengan ketentuan bahwa data akan dijaga kerahasiaannya oleh komite investigasi.","text":{"label":"Tulis laporan Anda dengan informasi selengkap mungkin.","desc":"Jelaskan sedetail mungkin apa yang terjadi, sebutkan orang-orang yang terlibat, dan bagaimana peristiwa itu terjadi."},"date":{"label":"Apakah Anda mengetahui tanggal kejadian?","desc":"Berikan tanggalnya, meskipun perkiraan, dan apakah kejadian masih berlangsung."},"city":{"label":"Kota"},"communication":{"label":"Tulis komunikasi Anda, dengan informasi selengkap mungkin."},"location":{"label":"Di mana kejadian berlangsung?","desc":"Berikan tempat kejadian, sebutkan kota, unit, dan sektor."},"knowAbout":{"label":"Bagaimana Anda mengetahui tentang kejadian ini?"},"witnesses":{"label":"Apakah Anda mengenal seseorang yang menyaksikan kejadian, atau memiliki pengetahuan tentangnya? Jika ya, sebutkan namanya."},"financialInfo":{"label":"Apakah ada kerugian finansial? Apakah Anda tahu nilainya?","desc":"Sebutkan jumlah kerugian yang Anda ketahui"}}},"mfu":{"attachmentList":"Daftar Lampiran","editImage":"Edit Gambar","dragNdrop":"Seret file untuk dilampirkan","preview":"Pratinjau","name":"Nama","size":"Ukuran","action":"Aksi","noImage":"Tidak Ada Gambar","edit":"Edit","remove":"Hapus","dragNdropHere":"Seret file ke sini untuk dilampirkan","or":"atau","selectFiles":"Pilih file","editFile":"Edit file","filenameField":"Masukkan nama file","image":"Gambar","zoomIn":"Perbesar","zoomOut":"Perkecil","rotate":"Putar","flipH":"Balik horizontal","flipV":"Balik vertikal","reset":"Reset","apply":"Terapkan","cancel":"Batal","save":"Simpan","errors":{"size":"Ukuran harus lebih dari 1 KB dan kurang dari 10 MB","extension":"Ekstensi tidak valid","timeout":"Waktu habis","abort":"Dibatalkan","network":"Kesalahan jaringan","server":"Kesalahan server","denied":"Ditolak","edit":"Mengedit...","unknown":"Kesalahan tidak dikenal","unsupported":"Browser Anda tidak mendukung fungsi ini"}},"router":{"Home":"Beranda","Report":"Laporan","ReportAlt":"Laporan","Questions and Suggestions":"Pertanyaan dan Saran","Follow up":"Tindak Lanjut","Ombudsman":"Ombudsman","Information":"Informasi","Committee":"Komite","Channel Policy":"Kebijakan Saluran","Code of Ethics":"Kode Etik","Compliance":"Kepatuhan","Channel Video":"Video Saluran","Data Subject Access Request":"Data Pribadi"},"martinelli":{"hero":{"badge":"LAPORAN 100% ANONIM","title":"Kerahasiaan dan Ketidakberpihakan.","titleSmall":"Bersama.","description":"{0} memiliki tim hukum independen yang siap menerima laporan Anda dengan kerahasiaan, anonimitas, keamanan, dan etika.","reportBtn":"Kirim laporan","howItWorks":"Bagaimana cara kerjanya?"},"followUp":{"badge":"LACAK LAPORAN ANDA","title":"Untuk memeriksa, cari berdasarkan nomor protokol laporan yang diajukan:","placeholder":"Masukkan nomor protokol","searchBtn":"Cari"},"organization":{"title":"Untuk organisasi yang lebih","titleHighlight":"etis","titleEnd":"","description":"Saluran yang tepat bagi siapa saja, internal maupun eksternal, untuk melaporkan dugaan korupsi, penipuan, dan kasus lain yang diatur dalam UU No. 12.846/2013, tindakan pelecehan berdasarkan UU 14.457/2022, serta tindakan lain yang bertentangan dengan komitmen kami terhadap etika dan integritas. Kami mengandalkan Anda!"},"features":{"confidentiality":{"title":"Kerahasiaan","desc":"Laporan Anda bersifat rahasia dan ditinjau secara eksklusif oleh Martinelli Advogados"},"nonRetaliation":{"title":"Non-retaliasi","desc":"Kami melarang segala bentuk pembalasan terhadap pelapor dan peserta investigasi"},"tracking":{"title":"Pelacakan","desc":"Setelah mengirim laporan, Anda dapat melacak perkembangan melalui portal ini"},"feedback":{"title":"Umpan Balik","desc":"Laporan mungkin terbukti atau tidak, tetapi Anda akan selalu menerima umpan balik."}},"process":{"title":"Proses yang sederhana, jelas, dan sepenuhnya","titleSmall":"tidak memihak","titleEnd":".","description":"Untuk memastikan ketidakberpihakan dan kerahasiaan, laporan Anda diterima dan ditinjau oleh Martinelli Advogados, firma hukum yang mengkhususkan diri dalam integritas dan etika perusahaan","details":"Laporan menjalani analisis hukum untuk menghindari konflik kepentingan atau pelanggaran ketidakberpihakan saat menerima laporan. Setelah dianalisis, laporan diteruskan dengan instruksi yang tepat hanya kepada orang-orang yang diperlukan dalam organisasi","check1":"Laporan Anda dikirim tanpa catatan identitas atau IP apa pun","check2":"Proses ini diaudit oleh tim eksternal dan independen","check3":"Anda mengikuti proses langkah demi langkah","reportBtn":"Kirim laporan"},"documents":{"title":"Bacaan","titleSmall":"penting","description":"Di sini Anda akan menemukan Kode Etik dan dokumen utama yang merinci bagaimana laporan diterima, prosedur internal, dan konsekuensi yang mungkin terjadi.","download":"Unduh file"},"container":{"documents":"Dokumen","help":"Bantuan","admin":"Administrasi","loading":"Memuat..."},"faq":{"sectionTitle":"tentang portal pelaporan?","sectionTitleHighlight":"Pertanyaan","q1":"Untuk apa saluran ini?","a1":"Saluran ini untuk melaporkan dengan aman dan, jika diinginkan, secara anonim, setiap tindakan karyawan, pemasok, atau penyedia layanan yang melanggar undang-undang, Kode Etik, atau aturan dan kebijakan internal institusi.","q2":"Siapa yang dapat menggunakan saluran ini?","a2":"Siapa saja yang memiliki pengetahuan tentang pelanggaran hukum, Kode Etik, atau aturan atau kebijakan internal institusi.","q3":"Apa yang dapat dilaporkan di Saluran?","a3":"Konsep pelaporan mencakup topik seperti dugaan atau kepastian tindakan korupsi, pelecehan, favoritisme terhadap pihak ketiga atau pemasok, pencurian, penipuan, penggelapan, dan berbagai perilaku lain yang melanggar hukum, Kode Etik, aturan atau kebijakan internal institusi yang berkaitan dengan karyawan, pemasok, penyedia layanan, dan siapa pun yang bertindak atas nama institusi.","q4":"Siapa yang akan menerima Laporan saya?","a4":"Laporan akan diterima oleh tim profesional berkualifikasi dari Martinelli Advogados dan, setelah penyaringan, akan diteruskan ke Komite yang bertanggung jawab untuk menyelidiki laporan. Semua yang terlibat dalam proses penerimaan dan investigasi.","q5":"Apakah saya perlu menyajikan bukti?","a5":"Tidak wajib, tetapi menyajikan atau menunjukkan elemen yang membuktikan fakta yang dilaporkan terjadi dapat menjadi penentu dalam investigasi dan dalam langkah-langkah yang akan diambil sebagai hasil dari laporan."},"footer":{"title":"Martinelli Advogados","contact":"Hubungi kami","copyright":"© 2023 Martinelli. Hak Cipta Dilindungi."}}}')},d614:function(e,a,n){"use strict";n.r(a);var i=n("7a28"),t=n("57d2"),o=(n("fd85"),n("15db"),n("c026"),n("4031"),n("c1c3"),n("22f4"),n("32ec"),n("6991"),n("4a00"),n("cbcf"),n("862d"),n("241c"),n("494a"),n("e832")),r=n("7e05"),s=function(){var e=this,a=e.$createElement,n=e._self._c||a;return n("router-view")},c=[],d={name:"App"},l=d,u=(n("1739"),n("a6c2")),m=Object(u["a"])(l,s,c,!1,null,null,null),p=m.exports,f=n("0522"),h=n("903e"),g=n("1da8"),b=(n("5a85"),n("534d"),n("3130"),n("2252"),n("64b0")),k=n.n(b);n("5812");function v(e){var a=arguments.length>1&&void 0!==arguments[1]&&arguments[1],n=document.createElement("a");a&&n.setAttribute("download",""),n.setAttribute("href",e),n.setAttribute("target","_blank"),document.body.appendChild(n),n.click(),document.body.removeChild(n)}function y(){return A.apply(this,arguments)}function A(){return A=Object(i["a"])(regeneratorRuntime.mark((function e(){var a,i;return regeneratorRuntime.wrap((function(e){while(1)switch(e.prev=e.next){case 0:return k.a.configure({showSpinner:!1}),e.next=3,Promise.resolve().then(n.bind(null,"0522"));case 3:a=e.sent,i=a.router,i.beforeEach((function(e,a,n){if(k.a.start(),e.redirectedFrom&&e.redirectedFrom.startsWith("/open/")){var i=h["a"].getters.portal;"grupogurgacz"===i.slug?v("https://siscompliance.com/codigos-grupo-gurgacz"):v("https://www.siscompliance.com/codigo-pvax/"),n(!1),k.a.done()}else if(e.redirectedFrom&&e.redirectedFrom.startsWith("/download/")){var t,o=h["a"].getters.company,r=h["a"].getters.portal,s=e.redirectedFrom.replace("/download/",""),c=!!o.compliance.oldFiles&&o.compliance.oldFiles[s],d=o.compliance.files;if(0===d.length&&c)t="https://s3.siscompliance.com.br/".concat(r._id,"/").concat(c);else{var l=d.find((function(e