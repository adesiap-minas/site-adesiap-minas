function loadAlert(data){const type=data.type||'info';const buttonText=data.buttonText||'Ok';const confirmText=data.confirmText||'Sim';const cancelText=data.cancelText||'Não';const closeStyleTemplate="alert-close";const title=data.title||"ATENÇÃO!!!";const message=data.message||"Tem certeza que deseja continuar?";const review=data.review||!1;const review_email=data.review_email||!1;let btnTemplate=`<button class="alert-button ${type}-bg ${type}-btn">${buttonText}</button>`;if(type==="question"||type==="question-info"){btnTemplate=`<div class="question-buttons">
			<button class="cancel-button error-bg error-btn">${cancelText}</button>
			<button class="confirm-button ${type}-bg ${type}-btn">${confirmText}</button>			
		</div>`}else if(type==="info"&&review_email){btnTemplate=`<div class="question-buttons">
			<button class="cancel-button error-bg error-btn">${cancelText}</button>
			<button class="confirm-email ${type}-bg ${type}-btn">${confirmText}</button>			
		</div>`}
const template=`<div class="alert-wrapper">
		<div class="alert-frame">
			<div class="alert-header ${type}-bg">
				<span class="${closeStyleTemplate}">X</span>
				<img class="alert-img" src="${crossapi.BASE_URL}/images/layout/icons-alert/${type}.svg" />
			</div>
			<div class="alert-body">
				<span class="alert-title">${title}</span>
				<span class="alert-message">${message}</span>
				${btnTemplate}
			</div>
		</div>
	</div>`;const body=document.querySelector("body");body.insertAdjacentHTML("afterend",template);const alertWrapper=document.querySelector(".alert-wrapper");const alertFrame=document.querySelector(".alert-wrapper .alert-frame");const alertClose=document.querySelector(`.alert-wrapper .${closeStyleTemplate}`);if(type==="question"){const confirmButton=document.querySelector(".alert-wrapper .confirm-button");const cancelButton=document.querySelector(".alert-wrapper .cancel-button");confirmButton.addEventListener("click",()=>{alertWrapper.remove();sendMasterForm()});cancelButton.addEventListener("click",()=>{alertWrapper.remove();if(review){jQuery("body,html").animate({scrollTop:($('nav').offset().top)},300);jQuery('.bloco-bullets-cadform #step-3 a').trigger('click')}})}else if(type==="info"&&review_email){const confirmEmail=document.querySelector(".alert-wrapper .confirm-email");const cancelButton=document.querySelector(".alert-wrapper .cancel-button");confirmEmail.addEventListener("click",()=>{jQuery('section.fields span.suggestion').remove();alertWrapper.remove();setTimeout(function(){jQuery('.bloco-cadform .arrows button#next').trigger('click')},100)});cancelButton.addEventListener("click",()=>{alertWrapper.remove();if(review_email){jQuery("body,html").animate({scrollTop:($('input[name=_reg_email]').offset().top-50)},300);$('input[name=_reg_email]').focus()}})}else{const alertButton=document.querySelector(".alert-wrapper .alert-button");alertButton.addEventListener("click",()=>{alertWrapper.remove()})}
alertClose.addEventListener("click",()=>{alertWrapper.remove()});alertFrame.addEventListener("click",(e)=>{e.stopPropagation()})}
