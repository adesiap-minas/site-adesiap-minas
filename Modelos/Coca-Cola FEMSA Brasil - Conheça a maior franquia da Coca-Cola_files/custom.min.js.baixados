function block_and_alert_cpf(){jQuery('.bloco-bullets-cadform').slideUp(300,function(){jQuery('.bloco-bullets-cadform').remove()});jQuery('form#cadastro').remove();jQuery('.bloco-cadform>div>div').append(`<div class="feedback"><figure><img src="${crossapi.BASE_URL}/images/layout/icons-form/cep-invalido.svg"/></figure><b style="font-size:24px;">🚧 Ops! Não estamos mais aceitando cadastros com CPF</b><br/><br/>O cadastro com a Coca-Cola FEMSA está <b>disponível apenas para empresas com CNPJ</b>.<br/><br/>Sabemos que muitos negócios incríveis começam de forma simples, e ficamos felizes por ter você aqui. Neste momento, estamos com um modelo de atendimento voltado apenas para quem já tem um CNPJ ativo (inclusive MEI - Microempreendedor individual).<br/><br/>Caso tenha interesse na compra dos produtos Coca-Cola FEMSA e não tenha um CNPJ, orientamos a compra dos nossos produtos em estabelecimentos revendedores na sua região.<br/><br/>Agradecemos pela compreensão e esperamos poder contar com você no futuro! ❤<br/><br/><a href="${crossapi.SITE_URL}/cadastro/formulario" class="link" id="Novo cadastro">Novo cadastro</a></div>`);return!1}
